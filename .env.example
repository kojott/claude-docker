# === REQUIRED ===
# Path to your projects on the host
PROJECTS_DIR=~/projects

# Anthropic API key (leave empty for OAuth login)
ANTHROPIC_API_KEY=

# === OPTIONAL ===
# GITHUB_TOKEN=ghp_...
# GIT_USER_NAME=Your Name
# GIT_USER_EMAIL=you@example.com
# CLAUDE_AUTOSTART=1     # 1 = immediately start cl session manager

# === CLIPBOARD ===
# Default: osc52 (works with modern terminals, zero config needed)
# CLIPBOARD_BACKEND=osc52    # x11 = Linux X11 (requires socket mount, see docs)
#                             # wayland = Linux Wayland (requires socket mount)

# === RESOURCES ===
# MEMORY_LIMIT=8g
# CPU_LIMIT=4.0
# PORT_DEV1=3000
# PORT_DEV2=5173
# PORT_DEV3=8080
